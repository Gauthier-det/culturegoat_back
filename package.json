{
  "name": "culturegoat-backend",
  "version": "1.0.0",
  "description": "Backend API for CultureGoat game",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "cross-env NODE_ENV=development node src/server.js",
    "prod": "cross-env NODE_ENV=production node src/server.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop culturegoat-api",
    "pm2:restart": "pm2 restart culturegoat-api",
    "pm2:logs": "pm2 logs culturegoat-api",
    "pm2:delete": "pm2 delete culturegoat-api",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["game", "quiz", "socket.io"],
  "author": "Gauthier-det",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.0.0",
    "isomorphic-dompurify": "^2.32.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.15.3",
    "pg": "^8.16.3",
    "socket.io": "^4.8.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
